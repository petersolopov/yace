{
  "name": "yace",
  "version": "0.0.7",
  "description": "tiny text editor with plugins",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./plugins/*": {
      "import": {
        "types": "./dist/plugins/*.d.ts",
        "default": "./dist/plugins/*.js"
      },
      "require": {
        "types": "./dist/plugins/*.d.cts",
        "default": "./dist/plugins/*.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "dev": "node e2e/server.js",
    "typecheck": "tsc --noEmit",
    "test": "c8 --all --include 'src/**/*.ts' --check-coverage --lines 100 --functions 100 --branches 99 node --test test/test.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "report": "c8 report --all --include 'src/**/*.ts' --reporter=text-lcov > coverage.txt",
    "build": "rm -rf ./dist && rollup -c && tsc -p tsconfig.build.json && node scripts/build-dts.js",
    "attw": "npm run build && attw --pack . --profile node16 --ignore-rules false-export-default",
    "prettier:write": "prettier --write '{src,examples,test,e2e,scripts}/**/*' playwright.config.js",
    "prettier:check": "prettier --check '{src,examples,test,e2e,scripts}/**/*' playwright.config.js",
    "release": "npx standard-version"
  },
  "keywords": [
    "text-editor",
    "editor",
    "code-editor",
    "textarea",
    "syntax-highlighting",
    "lightweight",
    "zero-dependencies",
    "prism",
    "react",
    "framework-agnostic"
  ],
  "author": "Peter Solopov <peter@solopov.dev>",
  "homepage": "https://github.com/petersolopov/yace",
  "bugs": "https://github.com/petersolopov/yace/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/petersolopov/yace"
  },
  "license": "MIT",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@playwright/test": "^1.61.1",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "c8": "^11.0.0",
    "prettier": "^3.9.4",
    "rollup": "^4.62.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "undom": "^0.4.0"
  }
}
